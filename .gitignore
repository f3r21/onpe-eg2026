# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Coverage
.coverage
coverage.xml
htmlcov/

# Envs y secretos
.env
*.pem
credentials.json
service-account*.json
credentials/

# Datos crudos (outputs del ingestor — muy grandes, regenerables)
data/*

# Excepción: los registries curados (YAML/JSON manualmente mantenidos) sí van al repo.
!data/registry/
!data/registry/**

# Logs y corridas
*.log
logs/
nohup.out

# Sistema
.DS_Store
.idea/
.vscode/

# LaunchAgents renderizados desde .template por install.sh (no commit)
ops/launchd/com.onpe.*.plist
!ops/launchd/com.onpe.*.plist.template

# Backups locales de git (git-filter-repo, manual git clones)
.git.backup-*/
