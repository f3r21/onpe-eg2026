# Variables de entorno opcionales para onpe-eg2026.
# Copiar a .env y descomentar solo lo que necesites.

# Directorio base del data lake.
# Default: ./data cuelga de la raíz del repo.
# ONPE_DATA_DIR=/tmp/onpe_test

# GCP project + bucket para descarga de PDFs binarios (scripts/download_pdfs.py).
# Solo necesario si corres el script con --gcs-bucket en lugar de disco local.
# Requiere también: gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=tu-proyecto-gcp
# GCS_BUCKET=gs://tu-bucket-pdfs
